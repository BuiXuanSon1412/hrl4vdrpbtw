{
  "name": "vrpbtw_ppo",
  "algorithm": "ppo",
  "seed": {
    "global_seed": 42,
    "env_seed": null,
    "data_seed": null
  },
  "env": {
    "problem_name": "vrpbtw",
    "problem_kwargs": {
      "n_customers": 10,
      "n_fleets": 2
    },
    "max_steps": null,
    "reward_scale": 1.0,
    "subtract_baseline": true,
    "dense_shaping": true
  },
  "network": {
    "network_type": "hacn",
    "embed_dim": 128,
    "n_heads": 8,
    "n_encoder_layers": 3,
    "dropout": 0.0,
    "clip_logits": 10.0,
    "ortho_init": true,
    "use_instance_norm": true,
    "hidden_dims": [
      256,
      256
    ]
  },
  "ppo": {
    "lr": 0.0003,
    "gamma": 0.99,
    "gae_lambda": 0.95,
    "clip_eps": 0.2,
    "value_coef": 0.5,
    "entropy_coef": 0.02,
    "max_grad_norm": 0.5,
    "n_epochs": 4,
    "mini_batch_size": 256,
    "rollout_len": 1024,
    "target_kl": 0.015,
    "normalize_advantages": true,
    "normalize_rewards": true,
    "reward_norm_eps": 1e-08
  },
  "dqn": {
    "lr": 0.0001,
    "gamma": 0.99,
    "buffer_capacity": 100000,
    "batch_size": 64,
    "target_update_freq": 500,
    "tau": 1.0,
    "train_freq": 4,
    "learning_starts": 1000,
    "eps_start": 1.0,
    "eps_end": 0.05,
    "eps_decay_steps": 50000,
    "use_per": false,
    "per_alpha": 0.6,
    "per_beta_start": 0.4,
    "per_beta_end": 1.0,
    "per_beta_steps": 100000
  },
  "train": {
    "total_timesteps": 100000,
    "log_interval": 5,
    "eval_interval": 20,
    "checkpoint_interval": 100,
    "checkpoint_dir": "checkpoints",
    "log_dir": "logs",
    "patience": 60,
    "min_delta": 0.0001,
    "n_eval_episodes": 10,
    "eval_deterministic": true,
    "eval_beam_width": 1,
    "curriculum": true,
    "curriculum_start": 3,
    "curriculum_end": 10,
    "curriculum_steps": 50000
  },
  "device": "cpu"
}